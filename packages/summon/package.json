{
  "name": "@runecraftai/summon",
  "version": "0.0.1",
  "description": "Interactive CLI for installing Arcanum agent skills",
  "license": "MIT",
  "type": "module",
  "main": "dist/summon",
  "bin": {
    "summon": "dist/summon"
  },
  "files": [
    "dist/",
    "src/",
    "scripts/",
    "package.json"
  ],
  "scripts": {
    "build": "bun build src/cli.ts --compile --target bun --outfile dist/summon",
    "dev": "bun run src/cli.ts",
    "postinstall": "node scripts/patch-clack.mjs"
  },
  "publishConfig": {
    "access": "public"
  },
  "keywords": [
    "arcanum",
    "agent",
    "skills",
    "cli",
    "installer"
  ],
  "dependencies": {
    "citty": "^0.1.6",
    "@clack/prompts": "^0.7.0",
    "picocolors": "^1.0.0"
  }
}
