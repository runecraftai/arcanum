{
  "name": "@runecraft/runes",
  "version": "0.1.0",
  "description": "Runes — persistent cross-session memory plugin for OpenCode",
  "author": "Arcanum",
  "license": "MIT",
  "homepage": "https://github.com/runecraftai/arcanum#readme",
  "repository": {
    "type": "git",
    "url": "https://github.com/runecraftai/arcanum.git"
  },
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.js"
    }
  },
  "bin": {
    "runes": "dist/bin/runes.js"
  },
  "engines": {
    "node": ">=22"
  },
  "files": [
    "dist",
    "skills",
    "schema"
  ],
  "scripts": {
    "build": "bun run script/build.ts",
    "clean": "rm -rf dist",
    "typecheck": "tsc --noEmit",
    "test": "bun test",
    "lint": "biome check src"
  },
  "keywords": [
    "opencode",
    "plugin",
    "memory",
    "agent",
    "runes"
  ],
  "publishConfig": {
    "registry": "https://registry.npmjs.org",
    "access": "public"
  },
  "dependencies": {
    "@opencode-ai/plugin": "^1.3.15",
    "zod": "^4.0.0"
  },
  "devDependencies": {
    "@runecraft/grimoire": "workspace:*",
    "@types/node": "^22.10.0",
    "bun-types": "^1.3.11",
    "typescript": "^6.0.2"
  }
}
