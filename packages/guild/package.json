{
  "name": "@runecraft/guild",
  "version": "0.19.1",
  "description": "Guild — multi-agent orchestration plugin for OpenCode",
  "author": "Arcanum",
  "license": "MIT",
  "homepage": "https://github.com/runecraftai/arcanum#readme",
  "repository": {
    "type": "git",
    "url": "https://github.com/runecraftai/arcanum.git"
  },
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.js"
    }
  },
  "files": [
    "dist/",
    "skills/",
    "schema/"
  ],
  "scripts": {
    "build": "bun run script/build.ts && tsc --emitDeclarationOnly",
    "clean": "rm -rf dist",
    "schema:config": "bun run script/generate-config-schema.ts",
    "schema:config:check": "bun run script/generate-config-schema.ts --check",
    "verify": "bun run script/verify.ts",
    "verify:publish": "bun run script/verify.ts --publish",
    "smoke-install": "bun run script/smoke-install.ts",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "bun run verify:publish && bun run smoke-install",
    "test": "bun test",
    "eval": "bun run script/eval.ts",
    "eval:smoke": "bun run script/eval.ts --suite prompt-smoke",
    "eval:phase2": "bun run script/eval.ts --suite agent-routing",
    "eval:coverage": "bun run script/verify-eval-coverage.ts",
    "eval:trend": "bun run script/eval-trend-report.ts"
  },
  "keywords": [
    "opencode",
    "plugin",
    "agents",
    "guild"
  ],
  "publishConfig": {
    "registry": "https://registry.npmjs.org",
    "access": "public"
  },
  "dependencies": {
    "@opencode-ai/plugin": "^1.3.15",
    "@opencode-ai/sdk": "^1.3.15",
    "jsonc-parser": "^3.3.1",
    "picocolors": "^1.1.1",
    "zod": "^4.0.0"
  },
  "devDependencies": {
    "bun": "^1.3.11",
    "bun-types": "^1.3.11",
    "typescript": "^6.0.2",
    "zod-to-json-schema": "^3.25.2"
  }
}
