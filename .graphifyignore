# .graphifyignore — files graphify should NOT index.
# (.gitignore is also respected automatically; this only adds more exclusions.)
# Syntax matches .gitignore, including ! negation.

# vendor / dependency noise
vendor/
node_modules/

# build / output dirs
bin/
obj/
dist/
build/
.next/
.nuxt/

# minified assets
*.min.*

# graphify's own local-only outputs (don't re-index the generated graph)
graphify-out/cache/
graphify-out/manifest.json
graphify-out/cost.json
